TELEGRAM_BOT_TOKEN=replace_me

# Database Configuration
# Use postgresql+psycopg2:// for SQLAlchemy with psycopg2 driver
# Use postgresql+psycopg:// for SQLAlchemy 2.0+ with psycopg3 driver
DATABASE_URL=postgresql+psycopg2://postgres:postgre@localhost:5432/job_brain
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgre
PGDATABASE=job_brain
LOG_LEVEL=INFO
BOT_POLL_INTERVAL_SECONDS=1.0
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=6
MAX_JOBS_PER_QUERY=20
SCRAPING_CONCURRENCY=8
REQUEST_TIMEOUT_SECONDS=20
MIN_DELAY_SECONDS=1.0
MAX_DELAY_SECONDS=3.5
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_TIMEOUT_MS=30000
ALLOWED_USER_AGENT_ROTATION=true

# AI Intelligence Layer Settings
AI_ANALYSIS_ENABLED=true
NETWORKING_GENERATOR_ENABLED=true
AI_PROVIDER=pattern
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
