TELEGRAM_BOT_TOKEN=replace_me

# Database Configuration
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/job_brain
AUTO_CREATE_TABLES=false
LOG_LEVEL=INFO
BOT_POLL_INTERVAL_SECONDS=1.0
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=6
MAX_JOBS_PER_QUERY=20
SCRAPING_CONCURRENCY=8
REQUEST_TIMEOUT_SECONDS=20
MIN_DELAY_SECONDS=1.0
MAX_DELAY_SECONDS=3.5
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_TIMEOUT_MS=30000
ALLOWED_USER_AGENT_ROTATION=true

# AI Intelligence Layer Settings
AI_ANALYSIS_ENABLED=true
NETWORKING_GENERATOR_ENABLED=true
ADMIN_USER_IDS=
AI_PROVIDER=pattern
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
